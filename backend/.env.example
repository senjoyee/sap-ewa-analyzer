# Backend environment configuration for SAP EWA Analyzer (Docker)
# Copy this file to .env and fill in your values.

# --- REQUIRED: Azure Blob Storage (used for uploads and outputs) ---
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=ewa-analyzer

# --- WORKFLOW CONFIGURATION ---
# Enable the new 3-phase agentic workflow (recommended for better quality and cost efficiency)
# Set to "true" to use: Phase 1 (Extraction) → Phase 2 (Analysis) → Phase 3 (Strategy)
# Set to "false" to use legacy single-agent workflow
USE_MULTI_PHASE_WORKFLOW=false

# Persist intermediate outputs for debugging/observability
# When true, uploads per-phase JSON files to the same container:
#   <base>_phase1_extraction.json
#   <base>_phase2_analysis.json
#   <base>_phase3_strategy.json
# These are removed by the delete-analysis endpoint together with other related files.
SAVE_PHASE_OUTPUTS=false

# --- OPTIONAL BUT REQUIRED FOR Document Chat (/api/chat) ---
# Provide your Azure OpenAI resource credentials and a deployment name.
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# One of these will be used by the chat endpoint as the model/deployment name
AZURE_OPENAI_SUMMARY_MODEL=<your-deployment-name>
# AZURE_OPENAI_FAST_MODEL=<alt-deployment-name>
# AZURE_OPENAI_DEPLOYMENT_NAME=<fallback-deployment-name>

# --- OPTIONAL ---
# Ensures logs flush immediately
PYTHONUNBUFFERED=1
