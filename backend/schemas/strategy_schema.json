{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/ewa_strategy/v1.0.json",
  "title": "EWAStrategyPhase",
  "description": "Phase 3: Generate executive summary and actionable recommendations",
  "type": "object",
  "properties": {
    "Executive Summary": {
      "type": "string",
      "description": "Concise newline-delimited bullet-point summary for C-level audience highlighting status, risks, and critical actions"
    },

    "Recommendations": {
      "type": "array",
      "description": "Detailed, actionable recommendations linked to key findings",
      "items": {
        "type": "object",
        "required": [
          "Recommendation ID",
          "Estimated Effort",
          "Responsible Area",
          "Linked issue ID",
          "Action",
          "Preventative Action"
        ],
        "properties": {
          "Recommendation ID": {
            "type": "string",
            "pattern": "^REC-[0-9]{2}$",
            "description": "Unique recommendation identifier (e.g., REC-01)"
          },

          "Estimated Effort": {
            "type": "object",
            "required": ["analysis", "implementation"],
            "properties": {
              "analysis":      { "type": "string", "enum": ["low", "medium", "high"] },
              "implementation":{ "type": "string", "enum": ["low", "medium", "high"] }
            },
            "additionalProperties": false
          },

          "Responsible Area": { 
            "type": "string", 
            "enum": [
              "SAP Basis Team",
              "Database Administration",
              "Operating System Administration",
              "Network & Connectivity",
              "Security / Compliance Team",
              "Application Development",
              "Functional / Business Process Owner",
              "Infrastructure / Hardware Team",
              "Third-Party Vendor",
              "Project / Change Management"
            ] 
          },
          
          "Linked issue ID": {
            "type": "string",
            "pattern": "^KF-[0-9]{2}$",
            "description": "Key finding ID this recommendation addresses (1:1 mapping for medium/high/critical findings)"
          },
          
          "Action": { 
            "type": "string", 
            "description": "Specific action steps as newline-delimited markdown bullets" 
          },
          
          "Preventative Action": { 
            "type": "string", 
            "description": "Preventative measures as newline-delimited markdown bullets" 
          }
        },
        "additionalProperties": false
      }
    }
  },

  "required": [
    "Executive Summary",
    "Recommendations"
  ],
  "additionalProperties": false
}
